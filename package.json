{
  "name": "@localixai/n8n-sdk",
  "version": "1.1.7",
  "description": "Type-safe TypeScript SDK for the n8n Public API",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "openapi.json"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build:esm": "tsc --project tsconfig.build.json --module ES2020 --outDir dist/esm",
    "build:cjs": "tsc --project tsconfig.build.json --module CommonJS --moduleResolution node --outDir dist/cjs",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist/types",
    "build:runtime-packages": "node scripts/write-runtime-package-jsons.mjs",
    "build": "npm run build:esm && npm run build:cjs && npm run build:types && npm run build:runtime-packages",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests/unit.test.ts",
    "test:smoke": "vitest run tests/smoke.test.ts tests/workflow-example.smoke.test.ts tests/control-plane.smoke.test.ts",
    "test:watch": "vitest",
    "example:workflow": "tsx docs/examples/sdk-simple-workflow-demo.ts",
    "example:backend": "tsx docs/examples/backend-control-plane.ts",
    "example:telegram-cloudflare": "tsx docs/examples/telegram-hi-bot-cloudflare.ts",
    "release:check": "npm run typecheck && npm run build && npm test && npm pack --dry-run",
    "release:prepare": "npm run release:check"
  },
  "keywords": [
    "n8n",
    "api",
    "sdk",
    "typescript",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localixai/n8n-sdk.git"
  },
  "homepage": "https://github.com/localixai/n8n-sdk#readme",
  "bugs": {
    "url": "https://github.com/localixai/n8n-sdk/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.1",
    "@types/node": "^25.7.0",
    "cloudflare": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
